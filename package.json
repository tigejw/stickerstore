{
  "name": "stickerstore",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "pg": "^8.20.0",
    "pg-format": "^1.0.4",
    "stripe": "^22.1.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.7.0",
    "@types/pg": "^8.20.0",
    "@types/pg-format": "^1.0.5",
    "@types/supertest": "^7.2.0",
    "jest": "^30.4.2",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  },
  "scripts": {
    "dev": "PGDATABASE=sticker_store nodemon --exec tsx ./src/listen.ts",
    "start": "tsx ./src/listen.ts",
    "setup-dbs": "psql -f ./db/setup.sql",
    "seed-dbs": "PGDATABASE=sticker_store tsx ./db/seeds/run-seeds",
    "test": "NODE_ENV=test jest"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "transform": {
      "^.+\\.(ts|tsx)$": "ts-jest"
    },
    "testMatch": [
      "**/__tests__/**/*.test.(ts|tsx|js)",
      "**/__tests__/**/*.ts",
      "**/__tests__/**/*.tsx"
    ],
    "moduleFileExtensions": [
      "ts",
      "tsx",
      "js",
      "jsx",
      "json",
      "node"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tigejw/stickerstore.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/tigejw/stickerstore/issues"
  },
  "homepage": "https://github.com/tigejw/stickerstore#readme"
}
